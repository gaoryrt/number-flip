{
  "name": "number-flip",
  "version": "1.3.0",
  "description": "Change number with flipping animation",
  "main": "dist/index.js",
  "module": "dist/number-flip.mjs",
  "types": "dist/number-flip.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/number-flip.d.ts",
      "import": "./dist/number-flip.mjs",
      "require": "./dist/number-flip.cjs",
      "default": "./dist/index.js"
    }
  },
  "repository": "https://github.com/gaoryrt/flip.git",
  "author": "gaoryrt",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');fs.renameSync('dist/index.global.js','dist/index.js');fs.renameSync('dist/number-flip.d.mts','dist/number-flip.d.ts')\"",
    "dev": "vite",
    "dev:test": "vite --mode test"
  }
}
